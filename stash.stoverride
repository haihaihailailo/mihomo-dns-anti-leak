  - name: Stash-国内服务
    type: select
    proxies: [DIRECT, Stash-中国-自动, Stash-中国节点, Stash-香港-自动, Stash-香港节点, Stash-节点选择]

  - name: Stash-GitHub
    type: select
    proxies: [Stash-香港-自动, Stash-新加坡-自动, Stash-日本-自动, Stash-美国-自动, Stash-香港节点, Stash-新加坡节点, Stash-日本节点, Stash-美国节点, Stash-节点选择]

  - name: Stash-YouTube
    type: select
    proxies: [Stash-节点选择, Stash-自动选择, Stash-香港-自动, Stash-香港节点, Stash-台湾-自动, Stash-台湾节点, Stash-日本-自动, Stash-日本节点, Stash-新加坡-自动, Stash-新加坡节点, Stash-美国-自动, Stash-美国节点, Stash-韩国-自动, Stash-韩国节点, Stash-越南-自动, Stash-越南节点, DIRECT]

  - name: Stash-Netflix
    type: select
    proxies: [Stash-节点选择, Stash-自动选择, Stash-香港-自动, Stash-香港节点, Stash-台湾-自动, Stash-台湾节点, Stash-日本-自动, Stash-日本节点, Stash-新加坡-自动, Stash-新加坡节点, Stash-美国-自动, Stash-美国节点, Stash-韩国-自动, Stash-韩国节点, Stash-越南-自动, Stash-越南节点, DIRECT]

  - name: Stash-AI
    type: select
    proxies: [Stash-美国节点, Stash-日本节点, Stash-新加坡节点, Stash-香港节点, Stash-美国-自动, Stash-日本-自动, Stash-新加坡-自动, Stash-香港-自动, Stash-节点选择]

  - name: Stash-谷歌服务
    type: select
    proxies: [Stash-节点选择, Stash-新加坡节点, Stash-日本节点, Stash-香港节点, Stash-美国节点, Stash-新加坡-自动, Stash-日本-自动, Stash-香港-自动, Stash-美国-自动, Stash-自动选择]

  - name: Stash-电报消息
    type: select
    proxies: [Stash-新加坡-自动, Stash-自动选择, Stash-节点选择, Stash-香港-自动, Stash-香港节点, Stash-台湾-自动, Stash-台湾节点, Stash-日本-自动, Stash-日本节点, Stash-新加坡节点, Stash-美国-自动, Stash-美国节点, Stash-韩国-自动, Stash-韩国节点, Stash-越南-自动, Stash-越南节点, Stash-中国-自动, Stash-中国节点, DIRECT]

  - name: Stash-微软服务
    type: select
    proxies: [DIRECT, Stash-香港-自动, Stash-新加坡-自动, Stash-中国-自动, Stash-香港节点, Stash-新加坡节点, Stash-中国节点, Stash-美国-自动, Stash-美国节点, Stash-节点选择]

  - name: Stash-TikTok
    type: select
    proxies: [Stash-节点选择, Stash-自动选择, Stash-香港-自动, Stash-香港节点, Stash-台湾-自动, Stash-台湾节点, Stash-日本-自动, Stash-日本节点, Stash-新加坡-自动, Stash-新加坡节点, Stash-美国-自动, Stash-美国节点, Stash-韩国-自动, Stash-韩国节点, Stash-越南-自动, Stash-越南节点, DIRECT]

  - name: Stash-苹果服务
    type: select
    proxies: [DIRECT, Stash-自动选择, Stash-节点选择, Stash-香港-自动, Stash-香港节点, Stash-台湾-自动, Stash-台湾节点, Stash-日本-自动, Stash-日本节点, Stash-新加坡-自动, Stash-新加坡节点, Stash-美国-自动, Stash-美国节点, Stash-韩国-自动, Stash-韩国节点, Stash-越南-自动, Stash-越南节点, Stash-中国-自动, Stash-中国节点]

  - name: Stash-Spotify
    type: select
    proxies: [Stash-节点选择, Stash-自动选择, Stash-香港-自动, Stash-香港节点, Stash-台湾-自动, Stash-台湾节点, Stash-日本-自动, Stash-日本节点, Stash-新加坡-自动, Stash-新加坡节点, Stash-美国-自动, Stash-美国节点, Stash-韩国-自动, Stash-韩国节点, Stash-越南-自动, Stash-越南节点, DIRECT]

  - name: Stash-哔哩哔哩港澳台
    type: select
    proxies: [DIRECT, Stash-自动选择, Stash-节点选择, Stash-香港-自动, Stash-香港节点, Stash-台湾-自动, Stash-台湾节点, Stash-日本-自动, Stash-日本节点, Stash-新加坡-自动, Stash-新加坡节点, Stash-美国-自动, Stash-美国节点, Stash-韩国-自动, Stash-韩国节点, Stash-越南-自动, Stash-越南节点, Stash-中国-自动, Stash-中国节点]

  - name: Stash-广告过滤
    type: select
    proxies: [REJECT, DIRECT]

  - name: Stash-全局直连
    type: select
    proxies: [DIRECT]

  - name: Stash-全部节点
    type: select
    include-all: true
    filter: "(?i)^(?!.*(官网|套餐|流量|异常|剩余|到期|过期|更新|联系|群|VIP)).*$"

  - name: Stash-自动选择
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://www.gstatic.com/generate_204
    filter: "(?i)^(?!.*(官网|套餐|流量|异常|剩余|到期|过期|更新|联系|群|VIP|回国|中国|CN|China|上海|北京|广州|深圳|江苏|浙江|🇨🇳)).*$"

  - name: Stash-香港节点
    type: select
    include-all: true
    filter: "(?i)(广港|香港|HK|Hong Kong|🇭🇰|HongKong)"

  - name: Stash-香港-自动
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://www.google.com.hk/generate_204
    filter: "(?i)(广港|香港|HK|Hong Kong|🇭🇰|HongKong)"

  - name: Stash-台湾节点
    type: select
    include-all: true
    filter: "(?i)(广台|台湾|台灣|TW|Tai Wan|🇹🇼|TaiWan|Taiwan)"

  - name: Stash-台湾-自动
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://www.google.com.tw/generate_204
    filter: "(?i)(广台|台湾|台灣|TW|Tai Wan|🇹🇼|TaiWan|Taiwan)"

  - name: Stash-日本节点
    type: select
    include-all: true
    filter: "(?i)(广日|日本|JP|川日|东京|大阪|泉日|埼玉|沪日|深日|🇯🇵|Japan)"

  - name: Stash-日本-自动
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://www.google.co.jp/generate_204
    filter: "(?i)(广日|日本|JP|川日|东京|大阪|泉日|埼玉|沪日|深日|🇯🇵|Japan)"

  - name: Stash-新加坡节点
    type: select
    include-all: true
    filter: "(?i)(广新|新加坡|SG|坡|狮城|🇸🇬|Singapore)"

  - name: Stash-新加坡-自动
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://www.google.com.sg/generate_204
    filter: "(?i)(广新|新加坡|SG|坡|狮城|🇸🇬|Singapore)"

  - name: Stash-美国节点
    type: select
    include-all: true
    filter: "(?i)(广美|US|美国|纽约|波特兰|达拉斯|俄勒|凤凰城|费利蒙|洛杉|圣何塞|圣克拉|西雅|芝加|🇺🇸|United States)"

  - name: Stash-美国-自动
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://www.google.com/generate_204
    filter: "(?i)(广美|US|美国|纽约|波特兰|达拉斯|俄勒|凤凰城|费利蒙|洛杉|圣何塞|圣克拉|西雅|芝加|🇺🇸|United States)"

  - name: Stash-韩国节点
    type: select
    include-all: true
    filter: "(?i)(广韩|韩国|韓國|KR|首尔|春川|🇰🇷|Korea)"

  - name: Stash-韩国-自动
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://www.google.co.kr/generate_204
    filter: "(?i)(广韩|韩国|韓國|KR|首尔|春川|🇰🇷|Korea)"

  - name: Stash-越南节点
    type: select
    include-all: true
    filter: "(?i)(越南|VN|Vietnam|Ho Chi Minh|HoChiMinh|🇻🇳)"

  - name: Stash-越南-自动
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://zalo.me
    filter: "(?i)(越南|VN|Vietnam|Ho Chi Minh|HoChiMinh|🇻🇳)"

  - name: Stash-中国节点
    type: select
    include-all: true
    filter: "(?i)(广中|中国|CN|China|上海|北京|广州|深圳|江苏|浙江|🇨🇳)"

  - name: Stash-中国-自动
    type: url-test
    include-all: true
    interval: 300
    tolerance: 50
    url: https://www.baidu.com
    filter: "(?i)(广中|中国|CN|China|上海|北京|广州|深圳|江苏|浙江|🇨🇳)"

rule-providers:
  reject:
    type: http
