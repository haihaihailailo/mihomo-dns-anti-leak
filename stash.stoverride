  tolerance: 50
  url: https://www.gstatic.com/generate_204
  expected-status: 204
  lazy: true
  hidden: true
  include-all: true
  filter: (?i)^(?!.*(官网|套餐|流量|异常|剩余|到期|过期|更新|联系|群|VIP|回国|中国|CN|China|上海|北京|广州|深圳|江苏|浙江|🇨🇳)).*$
