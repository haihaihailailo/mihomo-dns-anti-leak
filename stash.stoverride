name: Mihomo DNS 防泄露 Stash 覆写
summary: DNS 防泄露、fake-ip、IPv6、规则分流；不重复注入 proxy-groups，避免和订阅原有策略组重名。

# 说明：Stash .stoverride 会和原订阅合并，不能像 Mihomo JS 覆写一样替换同名 proxy-groups。
# 因此本文件只接管 DNS、rule-providers 和 rules，策略组名称沿用原订阅已有组名。

dns:
  enable: true
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - "+.lan"
    - "+.local"
    - "+.home.arpa"
    - "+.localdomain"
    - "router.asus.com"
    - "tplogin.cn"
    - "miwifi.com"
    - "tendawifi.com"
    - "+.msftconnecttest.com"
    - "+.msftncsi.com"
    - "+.push.apple.com"
    - "courier.push.apple.com"
    - "localhost.ptlogin2.qq.com"
    - "localhost.sec.qq.com"
    - "+.in-addr.arpa"
    - "+.ip6.arpa"
    - "time.*.com"
    - "time.*.gov"
    - "time.windows.com"
    - "pool.ntp.org"
    - "+.ntp.org"
    - "+.stun.*"
    - "stun.*.*"
    - "localhost.work.weixin.qq.com"
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://223.5.5.5/dns-query
    - https://doh.pub/dns-query
  nameserver-policy:
    "geosite:private": https://223.5.5.5/dns-query
    "geosite:cn": https://223.5.5.5/dns-query
    "geosite:microsoft": https://223.5.5.5/dns-query
    "+.windowsupdate.com": https://223.5.5.5/dns-query
    "+.download.windowsupdate.com": https://223.5.5.5/dns-query
    "+.mp.microsoft.com": https://223.5.5.5/dns-query
    "+.delivery.mp.microsoft.com": https://223.5.5.5/dns-query
    "+.dl.delivery.mp.microsoft.com": https://223.5.5.5/dns-query
    "geosite:geolocation-!cn": https://1.1.1.1/dns-query
    "geosite:google": https://1.1.1.1/dns-query
    "geosite:youtube": https://1.1.1.1/dns-query
    "geosite:openai": https://1.1.1.1/dns-query
    "geosite:github": https://1.1.1.1/dns-query
    "+.googleapis.cn": https://1.1.1.1/dns-query

rule-providers:
