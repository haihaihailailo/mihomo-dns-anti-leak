name: Mihomo DNS 防泄露 Stash 覆写
summary: DNS 防泄露、fake-ip、IPv6、策略组和规则全接管；策略组从主配置里的 SubStore proxy-provider 读取节点。

# Stash provider 接管版：主配置必须存在 proxy-providers.SubStore。
# 适用结构：stash-full 主配置只放一个 SubStore provider 链接，覆写接管 DNS / 策略组 / 规则。
# 注意：proxy-groups / rule-providers / rules 必须保留 #!replace；否则 Stash 会追加合并原配置数组，导致策略组重名。

dns: #!replace
  enable: true
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - "+.lan"
    - "+.local"
    - "+.home.arpa"
    - "+.localdomain"
    - "router.asus.com"
    - "tplogin.cn"
    - "miwifi.com"
    - "tendawifi.com"
    - "+.msftconnecttest.com"
    - "+.msftncsi.com"
    - "+.push.apple.com"
    - "courier.push.apple.com"
    - "localhost.ptlogin2.qq.com"
    - "localhost.sec.qq.com"
    - "+.in-addr.arpa"
    - "+.ip6.arpa"
    - "time.*.com"
    - "time.*.gov"
    - "time.windows.com"
    - "pool.ntp.org"
    - "+.ntp.org"
    - "+.stun.*"
    - "stun.*.*"
    - "localhost.work.weixin.qq.com"
  default-nameserver: #!replace
    - 223.5.5.5
    - 119.29.29.29
  nameserver: #!replace
    - https://223.5.5.5/dns-query
    - https://doh.pub/dns-query
  nameserver-policy: #!replace
    "geosite:private": https://223.5.5.5/dns-query
    "geosite:cn": https://223.5.5.5/dns-query
    "geosite:microsoft": https://223.5.5.5/dns-query
    "+.windowsupdate.com": https://223.5.5.5/dns-query
    "+.download.windowsupdate.com": https://223.5.5.5/dns-query
    "+.mp.microsoft.com": https://223.5.5.5/dns-query
    "+.delivery.mp.microsoft.com": https://223.5.5.5/dns-query
    "+.dl.delivery.mp.microsoft.com": https://223.5.5.5/dns-query
    "geosite:geolocation-!cn": https://1.1.1.1/dns-query
    "geosite:google": https://1.1.1.1/dns-query
    "geosite:youtube": https://1.1.1.1/dns-query
    "geosite:openai": https://1.1.1.1/dns-query
    "geosite:github": https://1.1.1.1/dns-query
    "+.googleapis.cn": https://1.1.1.1/dns-query

proxy-groups: #!replace
  - name: 节点选择
    type: select
    proxies: [自动选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡-自动, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, 中国-自动, 中国节点, 全部节点, DIRECT]

  - name: 漏网之鱼
    type: select
    proxies: [节点选择, 自动选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡-自动, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, 中国-自动, 中国节点, DIRECT, 全部节点]

  - name: 越南服务
    type: select
    proxies: [越南-自动, DIRECT, 越南节点, 新加坡-自动, 新加坡节点, 节点选择]

  - name: 国内服务
    type: select
    proxies: [DIRECT, 中国-自动, 中国节点, 香港-自动, 香港节点, 节点选择]

  - name: GitHub
    type: select
    proxies: [香港-自动, 新加坡-自动, 日本-自动, 美国-自动, 香港节点, 新加坡节点, 日本节点, 美国节点, 节点选择]

  - name: YouTube
    type: select
    proxies: [节点选择, 自动选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡-自动, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, DIRECT]

  - name: Netflix
    type: select
    proxies: [节点选择, 自动选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡-自动, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, DIRECT]

  - name: AI
    type: select
    proxies: [美国节点, 日本节点, 新加坡节点, 香港节点, 美国-自动, 日本-自动, 新加坡-自动, 香港-自动, 节点选择]

  - name: 谷歌服务
    type: select
    proxies: [节点选择, 新加坡节点, 日本节点, 香港节点, 美国节点, 新加坡-自动, 日本-自动, 香港-自动, 美国-自动, 自动选择]

  - name: 电报消息
    type: select
    proxies: [新加坡-自动, 自动选择, 节点选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, 中国-自动, 中国节点, DIRECT]

  - name: 微软服务
    type: select
    proxies: [DIRECT, 香港-自动, 新加坡-自动, 中国-自动, 香港节点, 新加坡节点, 中国节点, 美国-自动, 美国节点, 节点选择]

  - name: TikTok
    type: select
    proxies: [节点选择, 自动选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡-自动, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, DIRECT]

  - name: 苹果服务
    type: select
    proxies: [DIRECT, 自动选择, 节点选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡-自动, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, 中国-自动, 中国节点]

  - name: Spotify
    type: select
    proxies: [节点选择, 自动选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡-自动, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, DIRECT]

  - name: 哔哩哔哩港澳台
    type: select
    proxies: [DIRECT, 自动选择, 节点选择, 香港-自动, 香港节点, 台湾-自动, 台湾节点, 日本-自动, 日本节点, 新加坡-自动, 新加坡节点, 美国-自动, 美国节点, 韩国-自动, 韩国节点, 越南-自动, 越南节点, 中国-自动, 中国节点]

  - name: 广告过滤
    type: select
    proxies: [REJECT, DIRECT]

  - name: 全局直连
    type: select
    proxies: [DIRECT]

  - name: 全部节点
    type: select
    use: [SubStore]
    filter: "(?i)^(?!.*(官网|套餐|流量|异常|剩余|到期|过期|更新|联系|群|VIP)).*$"

  - name: 自动选择
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://www.gstatic.com/generate_204
    filter: "(?i)^(?!.*(官网|套餐|流量|异常|剩余|到期|过期|更新|联系|群|VIP|回国|中国|CN|China|上海|北京|广州|深圳|江苏|浙江|🇨🇳)).*$"

  - name: 香港节点
    type: select
    use: [SubStore]
    filter: "(?i)(广港|香港|HK|Hong Kong|🇭🇰|HongKong)"

  - name: 香港-自动
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://www.google.com.hk/generate_204
    filter: "(?i)(广港|香港|HK|Hong Kong|🇭🇰|HongKong)"

  - name: 台湾节点
    type: select
    use: [SubStore]
    filter: "(?i)(广台|台湾|台灣|TW|Tai Wan|🇹🇼|TaiWan|Taiwan)"

  - name: 台湾-自动
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://www.google.com.tw/generate_204
    filter: "(?i)(广台|台湾|台灣|TW|Tai Wan|🇹🇼|TaiWan|Taiwan)"

  - name: 日本节点
    type: select
    use: [SubStore]
    filter: "(?i)(广日|日本|JP|川日|东京|大阪|泉日|埼玉|沪日|深日|🇯🇵|Japan)"

  - name: 日本-自动
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://www.google.co.jp/generate_204
    filter: "(?i)(广日|日本|JP|川日|东京|大阪|泉日|埼玉|沪日|深日|🇯🇵|Japan)"

  - name: 新加坡节点
    type: select
    use: [SubStore]
    filter: "(?i)(广新|新加坡|SG|坡|狮城|🇸🇬|Singapore)"

  - name: 新加坡-自动
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://www.google.com.sg/generate_204
    filter: "(?i)(广新|新加坡|SG|坡|狮城|🇸🇬|Singapore)"

  - name: 美国节点
    type: select
    use: [SubStore]
    filter: "(?i)(广美|US|美国|纽约|波特兰|达拉斯|俄勒|凤凰城|费利蒙|洛杉|圣何塞|圣克拉|西雅|芝加|🇺🇸|United States)"

  - name: 美国-自动
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://www.google.com/generate_204
    filter: "(?i)(广美|US|美国|纽约|波特兰|达拉斯|俄勒|凤凰城|费利蒙|洛杉|圣何塞|圣克拉|西雅|芝加|🇺🇸|United States)"

  - name: 韩国节点
    type: select
    use: [SubStore]
    filter: "(?i)(广韩|韩国|韓國|KR|首尔|春川|🇰🇷|Korea)"

  - name: 韩国-自动
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://www.google.co.kr/generate_204
    filter: "(?i)(广韩|韩国|韓國|KR|首尔|春川|🇰🇷|Korea)"

  - name: 越南节点
    type: select
    use: [SubStore]
    filter: "(?i)(越南|VN|Vietnam|Ho Chi Minh|HoChiMinh|🇻🇳)"

  - name: 越南-自动
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://zalo.me
    filter: "(?i)(越南|VN|Vietnam|Ho Chi Minh|HoChiMinh|🇻🇳)"

  - name: 中国节点
    type: select
    use: [SubStore]
    filter: "(?i)(广中|中国|CN|China|上海|北京|广州|深圳|江苏|浙江|🇨🇳)"

  - name: 中国-自动
    type: url-test
    use: [SubStore]
    interval: 300
    tolerance: 50
    url: https://www.baidu.com
    filter: "(?i)(广中|中国|CN|China|上海|北京|广州|深圳|江苏|浙江|🇨🇳)"

rule-providers: #!replace
  reject:
    type: http
    behavior: domain
    format: mrs
    interval: 86400
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/category-ads-all.mrs
    path: ./ruleset/metacubex/category-ads-all.mrs
  private:
    type: http
